{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Raw Court Repository",
  "description": "A list of courts",
  "type": "array",
  "items": {
    "type": "object",
    "title": "Raw Court Group",
    "properties": {
      "name": {
        "type": "string"
      },
      "display_name": {
        "type": ["string", "null"]
      },
      "is_tribunal": {
        "type": "boolean"
      },
      "courts": {
        "type": "array",
        "items": {
          "$ref": "court.schema.json#"
        }
      }
    },
    "required": ["name", "display_name", "is_tribunal", "courts"],
    "additionalProperties": false
  }
}
